<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!--
        v1.0.6 — Normalized user & role tables (RBAC)
        Tables : APP_USER, APP_ROLE, USER_ROLE
        Author : hr-dev
        Date   : 2026-05-25

        NOTE: "USER" and "ROLE" are reserved words in Oracle — prefixed with APP_.
    -->

    <!-- ── Sequences ──────────────────────────────────────────────────────── -->

    <changeSet id="v1.0.6-seq-app-user" author="hr-dev">
        <createSequence sequenceName="SEQ_APP_USER"  startValue="1" incrementBy="1" minValue="1" cycle="false" ordered="true"/>
        <rollback><dropSequence sequenceName="SEQ_APP_USER"/></rollback>
    </changeSet>

    <changeSet id="v1.0.6-seq-app-role" author="hr-dev">
        <createSequence sequenceName="SEQ_APP_ROLE"  startValue="1" incrementBy="1" minValue="1" cycle="false" ordered="true"/>
        <rollback><dropSequence sequenceName="SEQ_APP_ROLE"/></rollback>
    </changeSet>

    <!-- ── APP_ROLE ────────────────────────────────────────────────────────── -->

    <changeSet id="v1.0.6-create-app-role" author="hr-dev">
        <comment>Role catalog — each row is one granted authority</comment>
        <createTable tableName="APP_ROLE">
            <column name="ID" type="NUMBER(10)">
                <constraints primaryKey="true" primaryKeyName="PK_APP_ROLE" nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR2(50)">
                <constraints nullable="false" unique="true" uniqueConstraintName="UK_APP_ROLE_NAME"/>
            </column>
            <column name="DESCRIPTION" type="VARCHAR2(200)"/>
        </createTable>
        <rollback><dropTable tableName="APP_ROLE"/></rollback>
    </changeSet>

    <!-- ── APP_USER ────────────────────────────────────────────────────────── -->

    <changeSet id="v1.0.6-create-app-user" author="hr-dev">
        <comment>Application user accounts — no role column, roles live in APP_ROLE via USER_ROLE</comment>
        <createTable tableName="APP_USER">
            <column name="ID" type="NUMBER(19)">
                <constraints primaryKey="true" primaryKeyName="PK_APP_USER" nullable="false"/>
            </column>
            <column name="USERNAME" type="VARCHAR2(100)">
                <constraints nullable="false" unique="true" uniqueConstraintName="UK_APP_USER_USERNAME"/>
            </column>
            <column name="EMAIL" type="VARCHAR2(200)">
                <constraints nullable="false" unique="true" uniqueConstraintName="UK_APP_USER_EMAIL"/>
            </column>
            <column name="PASSWORD_HASH" type="VARCHAR2(255)">
                <constraints nullable="false"/>
            </column>
            <column name="FULL_NAME" type="VARCHAR2(200)">
                <constraints nullable="false"/>
            </column>
            <column name="ENABLED" type="NUMBER(1)" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_AT" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_AT" type="TIMESTAMP"/>
        </createTable>
        <rollback><dropTable tableName="APP_USER"/></rollback>
    </changeSet>

    <!-- ── USER_ROLE (join table) ─────────────────────────────────────────── -->

    <changeSet id="v1.0.6-create-user-role" author="hr-dev">
        <comment>Many-to-many join between APP_USER and APP_ROLE</comment>
        <createTable tableName="USER_ROLE">
            <column name="USER_ID" type="NUMBER(19)">
                <constraints nullable="false"/>
            </column>
            <column name="ROLE_ID" type="NUMBER(10)">
                <constraints nullable="false"/>
            </column>
            <column name="ASSIGNED_AT" type="TIMESTAMP"/>
        </createTable>

        <addPrimaryKey tableName="USER_ROLE"
                       columnNames="USER_ID, ROLE_ID"
                       constraintName="PK_USER_ROLE"/>

        <addForeignKeyConstraint
                baseTableName="USER_ROLE" baseColumnNames="USER_ID"
                referencedTableName="APP_USER" referencedColumnNames="ID"
                constraintName="FK_UR_USER"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="USER_ROLE" baseColumnNames="ROLE_ID"
                referencedTableName="APP_ROLE" referencedColumnNames="ID"
                constraintName="FK_UR_ROLE"
                onDelete="CASCADE"/>

        <rollback><dropTable tableName="USER_ROLE"/></rollback>
    </changeSet>

    <!-- ── Seed roles ─────────────────────────────────────────────────────── -->

    <changeSet id="v1.0.6-seed-roles" author="hr-dev">
        <insert tableName="APP_ROLE">
            <column name="ID" valueSequenceNext="SEQ_APP_ROLE"/>
            <column name="NAME" value="ROLE_ADMIN"/>
            <column name="DESCRIPTION" value="Full system access"/>
        </insert>
        <insert tableName="APP_ROLE">
            <column name="ID" valueSequenceNext="SEQ_APP_ROLE"/>
            <column name="NAME" value="ROLE_RECRUITER"/>
            <column name="DESCRIPTION" value="HR recruiter access"/>
        </insert>
        <rollback>
            <delete tableName="APP_ROLE"><where>NAME IN ('ROLE_ADMIN','ROLE_RECRUITER')</where></delete>
        </rollback>
    </changeSet>

    <!-- ── Seed admin user ────────────────────────────────────────────────── -->

    <changeSet id="v1.0.6-seed-admin-user" author="hr-dev">
        <comment>Default admin account — password: Admin@1234</comment>
        <insert tableName="APP_USER">
            <column name="ID"            valueSequenceNext="SEQ_APP_USER"/>
            <column name="USERNAME"      value="admin"/>
            <column name="EMAIL"         value="admin@hr-agent.com"/>
            <!-- BCrypt of Admin@1234 -->
            <column name="PASSWORD_HASH" value="$2a$12$TwjWoMPTQoJFKl/GhvXo4.bxIXwsmhHCjSvVuwrHhB3SWbPsFW1Dq"/>
            <column name="FULL_NAME"     value="System Administrator"/>
            <column name="ENABLED"       valueNumeric="1"/>
            <column name="CREATED_AT"    valueDate="2026-05-25T00:00:00"/>
        </insert>
        <rollback>
            <delete tableName="APP_USER"><where>USERNAME = 'admin'</where></delete>
        </rollback>
    </changeSet>

    <!-- ── Assign ROLE_ADMIN to admin user ───────────────────────────────── -->

    <changeSet id="v1.0.6-seed-admin-role" author="hr-dev">
        <sql>
            INSERT INTO USER_ROLE (USER_ID, ROLE_ID)
            SELECT u.ID, r.ID
            FROM APP_USER u, APP_ROLE r
            WHERE u.USERNAME = 'admin'
              AND r.NAME = 'ROLE_ADMIN'
        </sql>
        <rollback>
            <sql>
                DELETE FROM USER_ROLE
                WHERE USER_ID  = (SELECT ID FROM APP_USER  WHERE USERNAME = 'admin')
                  AND ROLE_ID  = (SELECT ID FROM APP_ROLE  WHERE NAME     = 'ROLE_ADMIN')
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>