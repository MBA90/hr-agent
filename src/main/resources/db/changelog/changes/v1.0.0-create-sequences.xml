<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!--
        v1.0.0 — Create Oracle Sequences
        Author : hr-dev
        Date   : 2025-01-01
    -->

    <changeSet id="v1.0.0-seq-job-posting" author="hr-dev">
        <comment>Sequence for JOB_POSTING primary key</comment>
        <createSequence
                sequenceName="SEQ_JOB_POSTING"
                startValue="1"
                incrementBy="1"
                minValue="1"
                cycle="false"
                ordered="true"/>
        <rollback>
            <dropSequence sequenceName="SEQ_JOB_POSTING"/>
        </rollback>
    </changeSet>

    <changeSet id="v1.0.0-seq-candidate" author="hr-dev">
        <comment>Sequence for CANDIDATE primary key</comment>
        <createSequence
                sequenceName="SEQ_CANDIDATE"
                startValue="1"
                incrementBy="1"
                minValue="1"
                cycle="false"
                ordered="true"/>
        <rollback>
            <dropSequence sequenceName="SEQ_CANDIDATE"/>
        </rollback>
    </changeSet>

    <changeSet id="v1.0.0-seq-interview" author="hr-dev">
        <comment>Sequence for INTERVIEW primary key</comment>
        <createSequence
                sequenceName="SEQ_INTERVIEW"
                startValue="1"
                incrementBy="1"
                minValue="1"
                cycle="false"
                ordered="true"/>
        <rollback>
            <dropSequence sequenceName="SEQ_INTERVIEW"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
