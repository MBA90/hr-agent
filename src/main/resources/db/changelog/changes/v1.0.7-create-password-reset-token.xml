<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!--
        v1.0.7 — Password reset token table
        Author : hr-dev
        Date   : 2026-05-25
    -->

    <changeSet id="v1.0.7-seq-password-reset-token" author="hr-dev">
        <createSequence sequenceName="SEQ_PASSWORD_RESET_TOKEN"
                        startValue="1" incrementBy="1" minValue="1"
                        cycle="false" ordered="true"/>
        <rollback><dropSequence sequenceName="SEQ_PASSWORD_RESET_TOKEN"/></rollback>
    </changeSet>

    <changeSet id="v1.0.7-create-password-reset-token" author="hr-dev">
        <createTable tableName="PASSWORD_RESET_TOKEN">
            <column name="ID" type="NUMBER(19)">
                <constraints primaryKey="true" primaryKeyName="PK_PRT" nullable="false"/>
            </column>
            <column name="TOKEN" type="VARCHAR2(100)">
                <constraints nullable="false" unique="true" uniqueConstraintName="UK_PRT_TOKEN"/>
            </column>
            <column name="USER_ID" type="NUMBER(19)">
                <constraints nullable="false"/>
            </column>
            <column name="EXPIRES_AT" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="USED" type="NUMBER(1)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_AT" type="TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="PASSWORD_RESET_TOKEN" baseColumnNames="USER_ID"
                referencedTableName="APP_USER" referencedColumnNames="ID"
                constraintName="FK_PRT_USER"
                onDelete="CASCADE"/>

        <rollback><dropTable tableName="PASSWORD_RESET_TOKEN"/></rollback>
    </changeSet>

</databaseChangeLog>